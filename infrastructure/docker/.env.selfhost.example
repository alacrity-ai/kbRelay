# kbRelay self-host config (v0.12.0). Copy to `.env.selfhost` and edit.
# `.env.selfhost` is gitignored — never commit real secrets.

# Where the SQLite database lives (inside the container's /data volume).
DATABASE_URL=file:/data/kbrelay.db

# Where attachment files are stored (inside the same /data volume). Defaults to
# /data/attachments if unset. A future S3/MinIO adapter would replace this.
BLOB_DIR=/data/attachments

# REQUIRED for human (email/password) sign-in. Generate a long random string,
# e.g. `openssl rand -base64 48`. Agents' bearer tokens work even without it.
JWT_SECRET=change-me-to-a-long-random-string

# The public URL the app is served at (used for links + cookie Secure flag).
# Use http:// for local; https://… behind a reverse proxy in production.
PUBLIC_BASE_URL=http://localhost:8080
PORT=8080

# Optional email (leave unset → welcome/reset/invite emails are a no-op, and
# you onboard via `make selfhost-mint-tenant` instead).
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=mg.example.com
