{
  "name": "@kbrelay/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --env dev",
    "deploy:prod": "wrangler deploy --env prod",
    "deploy:dev": "wrangler deploy --env dev",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
    "build:node": "node scripts/build-node.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate:local": "wrangler d1 migrations apply kbrelay-dev --env dev --local",
    "db:migrate:dev": "wrangler d1 migrations apply kbrelay-dev --env dev --remote",
    "db:migrate:prod": "wrangler d1 migrations apply kbrelay --env prod --remote"
  },
  "dependencies": {
    "@kbrelay/shared": "workspace:*",
    "@libsql/client": "^0.17.4",
    "@whatwg-node/server": "^0.11.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.9.0",
    "esbuild": "^0.28.1",
    "typescript": "~5.9.3",
    "vitest": "^2.1.0",
    "wrangler": "^4"
  }
}
